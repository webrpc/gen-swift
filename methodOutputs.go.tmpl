{{- define "methodOutputs" -}}

{{- $method := .Method -}}
{{- $serviceAPIName := .ServiceAPIName -}}
{{- $methodAPIName := .MethodAPIName -}}

{{- if eq (len $method.Outputs) 0 -}}
Void
{{- else if $method.Succinct -}}
{{template "type" dict "Type" (index $method.Outputs 0).Type "TypeMap" .TypeMap}}
{{- else -}}
{{$serviceAPIName}}.{{$methodAPIName}}.Response
{{- end -}}
{{- end -}}
