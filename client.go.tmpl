{{define "client"}}

{{- $basePath := .BasePath -}}
{{- $schemaName := .SchemaName -}}
{{- $schemaPrefix := pascalCase $schemaName -}}
{{- $typeMap := .TypeMap -}}
{{- $types := .Types -}}
{{- $opts := .Opts -}}
{{- $reservedTypeNames := dict -}}
{{- range $_, $type := $types -}}
    {{- set $reservedTypeNames $type.Name true -}}
{{- end -}}
{{- $usedAPINames := dict -}}
{{- $usedClientNames := dict -}}

{{- if .Services}}
{{range $serviceIndex, $service := .Services}}{{if gt $serviceIndex 0}}

{{end}}
{{- $serviceBaseName := ternary (hasPrefix $service.Name $schemaPrefix) $service.Name (printf "%s%s" $schemaPrefix $service.Name) -}}
{{- $serviceAPIState := dict "name" "" "selected" false -}}
{{- range $_, $candidate := (list (printf "%sAPI" $serviceBaseName) (printf "%sServiceAPI" $serviceBaseName) (printf "%sWebRPCAPI" $serviceBaseName) (printf "%sGeneratedRPCAPI" $serviceBaseName) (printf "%sGeneratedRPCAPI%d" $serviceBaseName $serviceIndex)) -}}
    {{- if not (get $serviceAPIState "selected") -}}
        {{- $collisionState := dict "collision" false -}}
        {{- if or (exists $reservedTypeNames $candidate) (exists $usedAPINames $candidate) -}}
            {{- set $collisionState "collision" true -}}
        {{- end -}}
        {{- if not (get $collisionState "collision") -}}
            {{- set $serviceAPIState "name" $candidate -}}
            {{- set $serviceAPIState "selected" true -}}
            {{- set $usedAPINames $candidate true -}}
        {{- end -}}
    {{- end -}}
{{- end -}}
{{- $serviceAPIName := get $serviceAPIState "name" -}}
{{- $serviceClientState := dict "name" "" "selected" false -}}
{{- range $_, $candidate := (list (printf "%sClient" $serviceBaseName) (printf "%sServiceClient" $serviceBaseName) (printf "%sWebRPCClient" $serviceBaseName) (printf "%sGeneratedRPCClient" $serviceBaseName) (printf "%sGeneratedRPCClient%d" $serviceBaseName $serviceIndex)) -}}
    {{- if not (get $serviceClientState "selected") -}}
        {{- $collisionState := dict "collision" false -}}
        {{- if or (exists $reservedTypeNames $candidate) (exists $usedClientNames $candidate) -}}
            {{- set $collisionState "collision" true -}}
        {{- end -}}
        {{- if not (get $collisionState "collision") -}}
            {{- set $serviceClientState "name" $candidate -}}
            {{- set $serviceClientState "selected" true -}}
            {{- set $usedClientNames $candidate true -}}
        {{- end -}}
    {{- end -}}
{{- end -}}
{{- $serviceClientName := get $serviceClientState "name" -}}
public enum {{$serviceAPIName}} {
    public static let basePath = "{{$basePath}}{{$service.Name}}"
{{- range $_, $method := $service.Methods}}

    public enum {{$method.Name}} {
        public static let path = "/{{$method.Name}}"
        public static let urlPath = "{{$basePath}}{{$service.Name}}/{{$method.Name}}"
        {{- if and (not $method.Succinct) (gt (len $method.Inputs) 0) }}

        public struct Request: Codable, Sendable {
            {{- range $_, $field := $method.Inputs}}
                {{- $isExportable := true -}}
                {{- range $meta := $field.Meta -}}
                    {{- if exists $meta "json" -}}
                        {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                            {{- $isExportable = false -}}
                        {{- end -}}
                    {{- end -}}
                {{- end -}}
                {{- if $isExportable }}
            public let {{template "fieldName" dict "Field" $field}}: {{template "type" dict "Type" $field.Type "TypeMap" $typeMap "WebrpcTarget" $.WebrpcTarget}}{{if $field.Optional}}?{{end}}
                {{- end -}}
            {{- end}}

            public init(
                {{- $first := true -}}
                {{- range $_, $field := $method.Inputs}}
                    {{- $isExportable := true -}}
                    {{- range $meta := $field.Meta -}}
                        {{- if exists $meta "json" -}}
                            {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                                {{- $isExportable = false -}}
                            {{- end -}}
                        {{- end -}}
                    {{- end -}}
                    {{- if $isExportable -}}
                        {{- if not $first }}, {{end -}}
                        {{- $first = false -}}
                        {{template "fieldName" dict "Field" $field}}: {{template "type" dict "Type" $field.Type "TypeMap" $typeMap "WebrpcTarget" $.WebrpcTarget}}{{if $field.Optional}}? = nil{{end}}
                    {{- end -}}
                {{- end}}
            ) {
                {{- range $_, $field := $method.Inputs}}
                    {{- $isExportable := true -}}
                    {{- range $meta := $field.Meta -}}
                        {{- if exists $meta "json" -}}
                            {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                                {{- $isExportable = false -}}
                            {{- end -}}
                        {{- end -}}
                    {{- end -}}
                    {{- if $isExportable }}
                self.{{template "fieldName" dict "Field" $field}} = {{template "fieldName" dict "Field" $field}}
                    {{- end -}}
                {{- end}}
            }

            enum CodingKeys: String, CodingKey {
                {{- range $_, $field := $method.Inputs}}
                    {{- $isExportable := true -}}
                    {{- range $meta := $field.Meta -}}
                        {{- if exists $meta "json" -}}
                            {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                                {{- $isExportable = false -}}
                            {{- end -}}
                        {{- end -}}
                    {{- end -}}
                    {{- if $isExportable }}
                case {{template "fieldName" dict "Field" $field}} = "{{template "codingKey" dict "Field" $field}}"
                    {{- end -}}
                {{- end}}
            }
        }
        {{- end }}
        {{- if and (not $method.Succinct) (gt (len $method.Outputs) 0) }}

        public struct Response: Codable, Sendable {
            {{- range $_, $field := $method.Outputs}}
                {{- $isExportable := true -}}
                {{- range $meta := $field.Meta -}}
                    {{- if exists $meta "json" -}}
                        {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                            {{- $isExportable = false -}}
                        {{- end -}}
                    {{- end -}}
                {{- end -}}
                {{- if $isExportable }}
            public let {{template "fieldName" dict "Field" $field}}: {{template "type" dict "Type" $field.Type "TypeMap" $typeMap "WebrpcTarget" $.WebrpcTarget}}{{if $field.Optional}}?{{end}}
                {{- end -}}
            {{- end}}

            public init(
                {{- $first := true -}}
                {{- range $_, $field := $method.Outputs}}
                    {{- $isExportable := true -}}
                    {{- range $meta := $field.Meta -}}
                        {{- if exists $meta "json" -}}
                            {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                                {{- $isExportable = false -}}
                            {{- end -}}
                        {{- end -}}
                    {{- end -}}
                    {{- if $isExportable -}}
                        {{- if not $first }}, {{end -}}
                        {{- $first = false -}}
                        {{template "fieldName" dict "Field" $field}}: {{template "type" dict "Type" $field.Type "TypeMap" $typeMap "WebrpcTarget" $.WebrpcTarget}}{{if $field.Optional}}? = nil{{end}}
                    {{- end -}}
                {{- end}}
            ) {
                {{- range $_, $field := $method.Outputs}}
                    {{- $isExportable := true -}}
                    {{- range $meta := $field.Meta -}}
                        {{- if exists $meta "json" -}}
                            {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                                {{- $isExportable = false -}}
                            {{- end -}}
                        {{- end -}}
                    {{- end -}}
                    {{- if $isExportable }}
                self.{{template "fieldName" dict "Field" $field}} = {{template "fieldName" dict "Field" $field}}
                    {{- end -}}
                {{- end}}
            }

            enum CodingKeys: String, CodingKey {
                {{- range $_, $field := $method.Outputs}}
                    {{- $isExportable := true -}}
                    {{- range $meta := $field.Meta -}}
                        {{- if exists $meta "json" -}}
                            {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                                {{- $isExportable = false -}}
                            {{- end -}}
                        {{- end -}}
                    {{- end -}}
                    {{- if $isExportable }}
                case {{template "fieldName" dict "Field" $field}} = "{{template "codingKey" dict "Field" $field}}"
                    {{- end -}}
                {{- end}}
            }
        }
        {{- end }}

        {{- if eq (len $method.Inputs) 0 }}
        public static func encodeRequest(encoder _: JSONEncoder = WebRPCJSON.makeEncoder()) throws -> Data {
            Data("{}".utf8)
        }
        {{- else }}
        public static func encodeRequest(
            _ request: {{if $method.Succinct}}{{template "type" dict "Type" (index $method.Inputs 0).Type "TypeMap" $typeMap "WebrpcTarget" $.WebrpcTarget}}{{else}}Request{{end}},
            encoder: JSONEncoder = WebRPCJSON.makeEncoder()
        ) throws -> Data {
            try encoder.encode(request)
        }
        {{- end }}
        {{- if eq (len $method.Outputs) 0 }}

        public static func decodeResponse(_ data: Data, decoder _: JSONDecoder = WebRPCJSON.makeDecoder()) throws {
            _ = data
            return
        }
        {{- else }}

        public static func decodeResponse(
            _ data: Data,
            decoder: JSONDecoder = WebRPCJSON.makeDecoder()
        ) throws -> {{template "methodOutputs" dict "Method" $method "ServiceAPIName" $serviceAPIName "TypeMap" $typeMap}} {
            try decoder.decode({{template "methodOutputs" dict "Method" $method "ServiceAPIName" $serviceAPIName "TypeMap" $typeMap}}.self, from: data)
        }
        {{- end }}
    }
{{- end}}
}

public struct {{$serviceClientName}}: Sendable {
    public let baseURL: String
    public let transport: any WebRPCTransport
    public let headers: @Sendable () -> [String: String]

    public init(
        baseURL: String,
        transport: any WebRPCTransport = URLSessionWebRPCTransport(),
        headers: @escaping @Sendable () -> [String: String] = { [:] }
    ) {
        self.baseURL = baseURL
        self.transport = transport
        self.headers = headers
    }
    {{- range $_, $method := $service.Methods}}

    public func {{template "swiftLowerCamel" dict "Name" $method.Name}}({{template "methodInputs" dict "Method" $method "ServiceAPIName" $serviceAPIName "TypeMap" $typeMap}}) async throws{{if gt (len $method.Outputs) 0}} -> {{template "methodOutputs" dict "Method" $method "ServiceAPIName" $serviceAPIName "TypeMap" $typeMap}}{{end}} {
        let body = try {{$serviceAPIName}}.{{$method.Name}}.encodeRequest({{if gt (len $method.Inputs) 0}}request{{end}})
        let requestHeaders = makeWebRPCHeaders(
            headers(),
            includeWebRPCHeader: {{if eq (get $opts "webrpcHeader") true}}true{{else}}false{{end}}
        )
        {{- if eq (len $method.Outputs) 0 }}
        _ = try await executeWebRPC(
            baseURL: baseURL,
            urlPath: {{$serviceAPIName}}.{{$method.Name}}.urlPath,
            body: body,
            transport: transport,
            headers: requestHeaders,
            decodeSuccess: {{$serviceAPIName}}.{{$method.Name}}.decodeResponse,
        )
        return
        {{- else }}
        return try await executeWebRPC(
            baseURL: baseURL,
            urlPath: {{$serviceAPIName}}.{{$method.Name}}.urlPath,
            body: body,
            transport: transport,
            headers: requestHeaders,
            decodeSuccess: {{$serviceAPIName}}.{{$method.Name}}.decodeResponse,
        )
        {{- end }}
    }
    {{- end}}
}
{{end}}
{{- end}}
{{end}}
