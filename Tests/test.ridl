webrpc = v1

name = Helper
version = v1.0.0
basepath = /rpc

struct Ledger
  - amount: bigint
  - amounts: []bigint
  - maybe?: bigint

enum Flavor: string
  - Vanilla
  - Chocolate

struct Basket
  - counts: map<Flavor, uint32>

struct Box
  - payload: any

service Helper
  - GetUser(userId: uint64) => (code: uint32, username: string)
  - EchoLedger(Ledger) => (Ledger)
  - EchoBasket(Basket) => (Basket)
  - EchoBox(Box) => (Box)

error 200 UserNotFound "user not found"
