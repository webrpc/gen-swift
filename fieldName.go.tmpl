{{- define "fieldName" -}}

{{- $field := .Field -}}
{{- $candidate := $field.Name -}}
{{- $replacements := list
    (dict "from" "HTTPS" "to" "Https")
    (dict "from" "HTTP" "to" "Http")
    (dict "from" "OAuth" "to" "Oauth")
    (dict "from" "OIDC" "to" "Oidc")
    (dict "from" "PKCE" "to" "Pkce")
    (dict "from" "UUID" "to" "Uuid")
    (dict "from" "JSON" "to" "Json")
    (dict "from" "HTML" "to" "Html")
    (dict "from" "XML" "to" "Xml")
    (dict "from" "JWT" "to" "Jwt")
    (dict "from" "URL" "to" "Url")
    (dict "from" "URI" "to" "Uri")
    (dict "from" "RPC" "to" "Rpc")
    (dict "from" "API" "to" "Api")
    (dict "from" "OTP" "to" "Otp")
    (dict "from" "EOA" "to" "Eoa")
    (dict "from" "ABI" "to" "Abi")
    (dict "from" "SQL" "to" "Sql")
    (dict "from" "ID" "to" "Id")
 -}}
{{- range $replacement := $replacements -}}
    {{- $candidate = replace (get $replacement "from") (get $replacement "to") $candidate -}}
{{- end -}}
{{- $candidate = camelCase $candidate -}}

{{- if in $candidate
    "actor" "any" "as" "associatedtype" "async" "await" "borrowing" "break" "case" "catch" "class" "consuming"
    "continue" "convenience" "default" "defer" "deinit" "didSet" "distributed" "do" "dynamic" "each" "else"
    "enum" "extension" "fallthrough" "false" "fileprivate" "for" "func" "get" "guard" "if" "import" "in"
    "infix" "init" "inout" "internal" "is" "isolated" "lazy" "left" "let" "mutating" "nil" "none"
    "nonisolated" "open" "operator" "optional" "override" "package" "postfix" "precedencegroup" "prefix"
    "private" "protocol" "public" "repeat" "required" "rethrows" "return" "right" "self" "set" "some"
    "static" "struct" "subscript" "super" "switch" "throw" "throws" "true" "try" "typealias" "unowned"
    "var" "weak" "where" "while" "willSet" "yield"
 -}}
    {{- printf "`%s`" $candidate -}}
{{- else -}}
    {{- $candidate -}}
{{- end -}}

{{- end -}}
